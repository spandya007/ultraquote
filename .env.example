# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── PDF service (Railway) ────────────────────────────────────────────────────
# URL of the deployed Puppeteer service (see /pdf-service/README.md).
# Leave unset for local dev unless you want to test PDF download.
PDF_SERVICE_URL=https://your-pdf-service.up.railway.app
# Must match PDF_SERVICE_TOKEN set on the Railway service.
PDF_SERVICE_TOKEN=a-long-random-shared-secret

# ─── AI writing (Google Gemini) ───────────────────────────────────────────────
# Get a key at https://aistudio.google.com/apikey . Server-side only.
GEMINI_API_KEY=your-gemini-api-key

# ─── E-signature (DocuSeal cloud) ─────────────────────────────────────────────
# API token from https://console.docuseal.com → API. Server-side only.
DOCUSEAL_API_TOKEN=your-docuseal-token
# Optional: defaults to https://api.docuseal.com (use https://api.docuseal.eu for EU).
# DOCUSEAL_BASE_URL=https://api.docuseal.com
# Shared secret appended to the webhook URL (?secret=...) and verified on inbound.
DOCUSEAL_WEBHOOK_SECRET=a-long-random-shared-secret
